<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Tema claro de Errik (Material 3) -->
    <style name="Base.Theme.Erikpy" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/brand_on_primary</item>
        <item name="colorPrimaryContainer">@color/brand_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/brand_on_primary_container</item>

        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorOnSecondary">@color/brand_on_secondary</item>
        <item name="colorSecondaryContainer">@color/brand_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/brand_on_secondary_container</item>

        <item name="android:colorBackground">@color/light_background</item>
        <item name="colorSurface">@color/light_surface</item>
        <item name="colorOnSurface">@color/light_on_surface</item>
        <item name="colorSurfaceVariant">@color/light_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/light_on_surface_variant</item>
        <item name="colorOutline">@color/light_outline</item>
    </style>

    <style name="Theme.Erikpy" parent="Base.Theme.Erikpy" />

    <!-- Toolbar con identidad de marca (índigo, título blanco) -->
    <style name="Widget.Errik.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/brand_primary</item>
        <item name="titleTextColor">@color/brand_on_primary</item>
        <item name="subtitleTextColor">@color/brand_on_primary</item>
    </style>
</resources>
